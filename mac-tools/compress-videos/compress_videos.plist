<?xml version="1.0" encoding="UTF-8"?>
<!--
  LaunchAgent for the compress_videos watcher.

  Uses launchd's built-in WatchPaths trigger - the agent is invoked each
  time something changes inside ~/CompressMe/. The agent runs once, scans
  the folder for stable video files, processes them, and exits.
  ThrottleInterval prevents rapid-fire re-invocation (10s minimum gap).

  Path placeholders __HOME__ and __SCRIPT_DIR__ are replaced by setup_watch.sh
  before this file is copied to ~/Library/LaunchAgents/.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hakiel.compress-videos</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__SCRIPT_DIR__/compress_videos_watch.sh</string>
  </array>

  <key>WatchPaths</key>
  <array>
    <string>__HOME__/CompressMe</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/compress_videos.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/compress_videos.log</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>__SCRIPT_DIR__/bin:/usr/local/bin:/usr/bin:/bin</string>
    <key>HOME</key>
    <string>__HOME__</string>
  </dict>

  <key>WorkingDirectory</key>
  <string>__SCRIPT_DIR__</string>
</dict>
</plist>
