{
  "name": "mcp-automation",
  "version": "1.0.0",
  "description": "MCP server with Google Workspace, iMessage, and HTTP automation tools",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "npx ts-node --esm src/index.ts",
    "auth:google": "npx ts-node --esm src/auth/google.ts",
    "auth:quickbooks": "npx ts-node --esm src/auth/quickbooks.ts",
    "auth:notary-gmail": "node dist/auth/google-notary.js",
    "test": "tsc && node --test tests/"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "@notionhq/client": "^5.17.0",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "googleapis": "^144.0.0",
    "mcp-remote": "^0.1.38",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.59.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.0"
  }
}
